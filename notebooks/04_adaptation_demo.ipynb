"# 3. Load Data and Base Model\n",
"\n",
"# A. Mock Source and Target Data (must match 03_stress_simulation.ipynb)\n",
"X_mock = np.random.randn(N_EPOCHS, N_CHANNELS, N_TIMES).astype(np.float32)\n",
"y_mock = np.array([1, 2] * (N_EPOCHS // 2))\n",
"X_tensor = torch.from_numpy(X_mock).unsqueeze(1)\n",
"le = LabelEncoder()\n",
"y_encoded = le.fit_transform(y_mock)\n",
"y_tensor = torch.from_numpy(y_encoded).long()\n",
"\n",
"_, X_test_clean, , y_test_clean = train_test_split(\n",
"    X_tensor, y_tensor, test_size=0.2, random_state=42, stratify=y_tensor\n",
")\n",
"\n",
"# Mock Stressed Data generation (same as Notebook 03 for consistency)\n",
"X_test_clean_np = X_test_clean.squeeze(1).numpy()\n",
"try:\n",
"    # If apply_simulated_stress ehttps://www.google.com/search?q=xists, use it\n",
"    X_test_stressed_np = apply_simulated_stress(X_test_clean_np, sfreq=250, severity=1.0)\n",
"ehttps://www.google.com/search?q=xcept NameError:\n",
"    # Mock Stress: Shift data mean to simulate severe domain shift\n",
"    X_test_stressed_np = X_test_clean_np + 5.0 * np.random.randn(X_test_clean_np.shape)\n",
"\n",
"X_test_stressed = torch.from_numpy(X_test_stressed_np).unsqueeze(1).float()\n",
"\n",
"# Datasets and Loaders\n",
"source_dataset = TensorDataset(X_test_clean, y_test_clean)\n",
"target_dataset = TensorDataset(X_test_stressed, y_test_clean) # Labels kept for evaluation only\n",
"\n",
"source_loader = DataLoader(source_dataset, batch_size=BATCH_SIZE, shuffle=True)\n",
"target_loader = DataLoader(target_dataset, batch_size=BATCH_SIZE, shuffle=True)\n",
"\n",
"# B. Load Base Model\n",
"baseline_model = EEGNet(\n",
"    Chans=N_CHANNELS, Samples=N_TIMES, F1=8, D=2, F2=16, kernLength=64, num_classes=N_CLASSES\n",
").to(DEVICE)\n",
"baseline_model.load_state_dict(torch.load(MODEL_PATH, map_location=DEVICE))\n",
"baseline_model.eval()\n",
"print("Baseline model loaded and data prepared.")"
]
