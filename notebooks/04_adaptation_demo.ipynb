"# 4. Prepare Adapted Model and Optimizer\n",
"\n",
"# Create the Adaptive Model: Start with a deep copy of the baseline model\n",
"adapted_model = deepcopy(baseline_model).to(DEVICE)\n",
"adapted_model.train() # Set to training mode for adaptation\n",
"\n",
"# Freeze the Classifier (Final Linear Layer) since we only want to update the feature ehttps://www.google.com/search?q=xtractor\n",
"# based on unsupervised alignment (CORAL)\n",
"for param in adapted_model.classifier.parameters():\n",
"    param.requires_grad = False\n",
"\n",
"# Set up optimizer only for the remaining feature ehttps://www.google.com/search?q=xtractor parameters\n",
"optimizer_adapt = optim.Adam(\n",
"    filter(lambda p: p.requires_grad, adapted_model.parameters()), \n",
"    lr=ADAPTATION_LR\n",
")\n",
"\n",
"# Re-implement the feature ehttps://www.google.com/search?q=xtraction hook (same as notebook 03) for the adaptation loop\n",
"def ehttps://www.google.com/search?q=xtract_features(model, X_batch):\n",
"    # Forward pass until the feature ehttps://www.google.com/search?q=xtraction layer\n",
"    https://www.google.com/search?q=x = model.eegnet(X_batch)\n",
"    https://www.google.com/search?q=x = model.classifier0 # Output of Flatten/Dropout layer (features)\n",
"    return https://www.google.com/search?q=x"
]
},
