"source": [
"# 5. Adaptation Loop (CORAL)\n",
"\n",
"print(f"\nStarting Adaptation for {ADAPTATION_EPOCHS} epochs...")\n",
"\n",
"source_iter = iter(source_loader)\n",
"target_iter = iter(target_loader)\n",
"\n",
"for epoch in range(ADAPTATION_EPOCHS):\n",
"    total_adapt_loss = 0\n",
"    batches = 0\n",
"    \n",
"    for X_target, _ in target_loader: # We only need the input (X) from the target loader\n",
"        try:\n",
"            X_source, _ = nehttps://www.google.com/search?q=xt(source_iter)\n",
"        ehttps://www.google.com/search?q=xcept StopIteration:\n",
"            # Reset the source iterator when it runs out of batches\n",
"            source_iter = iter(source_loader)\n",
"            X_source, _ = nehttps://www.google.com/search?q=xt(source_iter)\n",
"        \n",
"        X_source, X_target = X_source.to(DEVICE), X_target.to(DEVICE)\n",
"        \n",
"        # 1. Ehttps://www.google.com/search?q=xtract Features\n",
"        features_source = ehttps://www.google.com/search?q=xtract_features(adapted_model, X_source)\n",
"        features_target = ehttps://www.google.com/search?q=xtract_features(adapted_model, X_target)\n",
"        \n",
"        # 2. Calculate Adaptation Loss\n",
"        adapt_loss = CORAL_WEIGHT * coral_loss(features_source, features_target)\n",
"        \n",
"        # 3. Optimize (minimize the domain discrepancy)\n",
"        optimizer_adapt.zero_grad()\n",
"        adapt_loss.backward()\n",
"        optimizer_adapt.step()\n",
"        \n",
"        total_adapt_loss += adapt_loss.item()\n",
"        batches += 1\n",
"        \n",
"    avg_loss = total_adapt_loss / batches\n",
"    print(f'Epoch [{epoch+1}/{ADAPTATION_EPOCHS}], CORAL Loss: {avg_loss:.6f}')\n",
"    \n",
"print("Adaptation Complete.")"
]
},
