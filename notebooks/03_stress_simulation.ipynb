"source": [
"# 03 - Baseline Decoder Failure Under Stress Simulation\n",
"\n",
"This notebook demonstrates the core problem of domain shift in BCI: the failure of a decoder trained on clean data (Source Domain) when applied to data contaminated by simulated spaceflight stressors (Target Domain). We will use the trained EEGNet model and evaluate its performance on both data domains, followed by a feature space visualization to explain the drop in accuracy."
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 1. Setup and Imports\n",
"import numpy as np\n",
"import torch\n",
"import torch.nn as nn\n",
"from torch.utils.data import TensorDataset, DataLoader\n",
"from sklearn.model_selection import train_test_split\n",
"from sklearn.preprocessing import LabelEncoder\n",
"import sys\n",
"import os\n",
"\n",
"# Add the src directory to the path to import custom modules\n",
"sys.path.append(os.path.join('..', 'src'))\n",
"\n",
"from utils.metrics import calculate_accuracy\n",
"from models.eegnet import EEGNet # Assuming EEGNet class is available\n",
"from data.add_stressors import apply_simulated_stress # *** Placeholder for stress simulation *\n",
"from utils.viz import plot_tsne_features\n",
"\n",
"# Configuration\n",
"DEVICE = torch.device("cuda" if torch.cuda.is_available() else "cpu")\n",
"MODEL_PATH = os.path.join('..', 'models', 'eegnet_baseline.pth')"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 2. Load Model and Data Configuration\n",
"\n",
"# Data Configuration (Must match notebook 02)\n",
"N_EPOCHS = 160\n",
"N_CHANNELS = 64\n",
"N_TIMES = 1251\n",
"N_CLASSES = 2\n",
"TEST_SIZE = 0.2\n",
"BATCH_SIZE = 16\n",
"\n",
"# A. Initialize Baseline Model Structure\n",
"model = EEGNet(\n",
"    Chans=N_CHANNELS, Samples=N_TIMES, F1=8, D=2, F2=16, kernLength=64, num_classes=N_CLASSES\n",
").to(DEVICE)\n",
"\n",
"# B. Load Trained Weights\n",
"try:\n",
"    model.load_state_dict(torch.load(MODEL_PATH, map_location=DEVICE))\n",
"    print("Baseline EEGNet weights loaded successfully.")\n",
"    model.eval() # Set model to evaluation mode\n",
"except FileNotFoundError:\n",
"    print(f"Error: Model file not found at {MODEL_PATH}. Run notebook 02 first.")\n",
"    # Exit or mock model for demonstration\n",
"except Exception as e:\n",
"    print(f"Error loading model: {e}")"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 3. Prepare Test Data (Source Domain)\n",
"\n",
"# Re-mock the clean data and labels for the testing pipeline\n",
"X_mock = np.random.randn(N_EPOCHS, N_CHANNELS, N_TIMES).astype(np.float32)\n",
"y_mock = np.array([1, 2] * (N_EPOCHS // 2))\n",
"\n",
"X_tensor = torch.from_numpy(X_mock).unsqueeze(1)\n",
"le = LabelEncoder()\n",
"y_encoded = le.fit_transform(y_mock)\n",
"y_tensor = torch.from_numpy(y_encoded).long()\n",
"\n",
"# Split (must use the same random state and stratify as notebook 02)\n",
"_, X_test_clean, _, y_test_clean = train_test_split(\n",
"    X_tensor, y_tensor, test_size=TEST_SIZE, random_state=42, stratify=y_tensor\n",
")\n",
"\n",
"clean_dataset = TensorDataset(X_test_clean, y_test_clean)\n",
"clean_loader = DataLoader(clean_dataset, batch_size=BATCH_SIZE, shuffle=False)\n",
"\n",
"print(f"Clean Test Samples (Source Domain): {len(X_test_clean)}")"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 4. Simulate Stressors (Target Domain)\n",
"\n",
"# NOTE: The implementation of apply_simulated_stress should be in src/data/add_stressors.py.\n",
"# For this notebook, we mock the result of a severe stress simulation.\n",
"\n",
"print("Applying Simulated Stressors (EMG noise, baseline drift, etc.)...")\n",
"\n",
"# 4a. Apply Stressors to the NumPy array before converting to tensor\n",
"X_test_clean_np = X_test_clean.squeeze(1).numpy() # (N_samples, N_channels, N_times)\n",
"\n",
"try:\n",
"    # Apply the stress function (will significantly change the signal distribution)\n",
"    X_test_stressed_np = apply_simulated_stress(X_test_clean_np, sfreq=250, severity=1.0)\n",
"except NameError:\n",
"    print("WARNING: apply_simulated_stress not found. Simulating stress via simple shift for demonstration.")\n",
"    # Mock Stress: Shift data mean to simulate severe domain shift\n",
"    X_test_stressed_np = X_test_clean_np + 5.0 * np.random.randn(X_test_clean_np.shape)\n",
"\n",
"# Convert back to PyTorch tensor format (N, 1, C, T)\n",
"X_test_stressed = torch.from_numpy(X_test_stressed_np).unsqueeze(1).float()\n",
"stressed_dataset = TensorDataset(X_test_stressed, y_test_clean) # Labels are preserved\n",
"stressed_loader = DataLoader(stressed_dataset, batch_size=BATCH_SIZE, shuffle=False)\n",
"\n",
"print(f"Stressed Test Samples (Target Domain): {len(X_test_stressed)}")"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 5. Evaluation Function\n",
"def evaluate_model(model, data_loader, device):\n",
"    """Evaluates the model and returns accuracy and features."""\n",
"    model.eval()\n",
"    y_true = []\n",
"    y_pred = []\n",
"    all_features = []\n",
"\n",
"    # Temporarily modify the forward pass to capture features (output of the final Conv layer)\n",
"    # We assume the output before the final Dense layer is the feature vector.\n",
"    def hook_fn(module, input, output):\n",
"        # Flatten the convolutional features and store them\n",
"        all_features.append(output.cpu().numpy())\n",
"\n",
"    # Attach the hook to the layer just before the final classifier (e.g., the final Dropout layer or before the Linear layer)\n",
"    # In EEGNet, the features are flattened after the final AveragePooling and Dropout\n",
"    # We attach it to the layer before the final classification layer (model.classifier[1])\n",
"    feature_extractor_layer = model.classifier[0] # Assumes this is the Flatten layer or equivalent dropout before the Linear layer\n",
"    hook = feature_extractor_layer.register_forward_hook(hook_fn)\n",
"\n",
"    with torch.no_grad():\n",
"        for X_batch, y_batch in data_loader:\n",
"            X_batch = X_batch.to(device)\n",
"            outputs = model(X_batch)\n",
"            _, predicted = torch.max(outputs.data, 1)\n",
"            \n",
"            y_true.extend(y_batch.cpu().numpy())\n",
"            y_pred.extend(predicted.cpu().numpy())\n",
"\n",
"    hook.remove() # Remove the hook after evaluation\n",
"\n",
"    accuracy = calculate_accuracy(np.array(y_true), np.array(y_pred))\n",
"    # Concatenate features from all batches\n",
"    final_features = np.concatenate(all_features, axis=0)\n",
"    \n",
"    return accuracy, final_features"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 6. Baseline Performance on Source (Clean) Domain\n",
"\n",
"print("Evaluating on Source (Clean) Test Data...")\n",
"clean_acc, clean_features = evaluate_model(model, clean_loader, DEVICE)\n",
"\n",
"print(f"[Source Domain] Baseline Accuracy: {clean_acc:.4f}")\n",
"print("This accuracy should be high, demonstrating the model is well-trained on clean data.")"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 7. Baseline Performance on Target (Stressed) Domain\n",
"\n",
"print("\nEvaluating on Target (Stressed) Test Data...")\n",
"stressed_acc, stressed_features = evaluate_model(model, stressed_loader, DEVICE)\n",
"\n",
"print(f"[Target Domain] Baseline Accuracy: {stressed_acc:.4f}")\n",
"print(" Accuracy Drop *** This low value confirms the domain shift problem due to stressors.")"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 8. Feature Space Visualization (t-SNE)\n",
"\n",
"print("\nVisualizing Feature Space Alignment...")\n",
"\n",
"# Note: The features stored by the hook will be the output of the layer right before the final Linear classifier.\n",
"\n",
"plot_tsne_features(\n",
"    source_features=clean_features,\n",
"    target_features=stressed_features,\n",
"    title="Domain Shift: Baseline Features (Clean vs. Stressed)"\n",
")\n",
"\n",
"print("The resulting t-SNE plot should show two distinct, separated clusters, indicating that the features extracted by the baseline model for the stressed data are significantly different from the features extracted for the clean data. This misalignment explains the poor decoding performance on the Target Domain.")"
]
}
],
