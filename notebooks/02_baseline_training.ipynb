"source": [
"# 02 - Baseline EEGNet Training\n",
"\n",
"This notebook focuses on implementing and training the baseline deep learning model (EEGNet) using the clean, preprocessed data (Source Domain) prepared in the previous notebook (01_data_exploration.ipynb). This model will serve as our benchmark before we introduce simulated stressors and adaptive techniques."
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 1. Setup and Imports\n",
"\n",
"import numpy as np\n",
"import torch\n",
"import torch.nn as nn\n",
"from torch.utils.data import TensorDataset, DataLoader\n",
"from sklearn.model_selection import train_test_split\n",
"from sklearn.preprocessing import LabelEncoder\n",
"import sys\n",
"import os\n",
"\n",
"# Add the src directory to the path to import custom modules\n",
"sys.path.append(os.path.join('..', 'src'))\n",
"\n",
"from utils.metrics import calculate_accuracy\n",
"from models.eegnet import EEGNet # Assumes EEGNet is implemented here\n",
"\n",
"# Set device\n",
"DEVICE = torch.device("cuda" if torch.cuda.is_available() else "cpu")\n",
"print(f"Using device: {DEVICE}")"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 2. Load and Prepare Data\n",
"\n",
"# NOTE: In a real scenario, we would load the saved X and y from the previous step.\n",
"# For a runnable notebook, we simulate the processed data shapes from Subject 1.\n",
"\n",
"N_EPOCHS = 160\n",
"N_CHANNELS = 64\n",
"N_TIMES = 1251 # Corresponds to 5s at 250Hz (t_min=-1, t_max=4)\n",
"N_CLASSES = 2 # Left Hand (T1) and Right Hand (T2)\n",
"\n",
"# Mock data: X (n_epochs, n_channels, n_times)\n",
"X_mock = np.random.randn(N_EPOCHS, N_CHANNELS, N_TIMES).astype(np.float32)\n",
"# Mock labels: y (labels 1 and 2 need to be mapped to 0 and 1)\n",
"y_mock = np.array([1, 2] * (N_EPOCHS // 2))\n",
"\n",
"print(f"Mock Data Shape X: {X_mock.shape}")\n",
"\n",
"# EEGNet expects data in format (n_epochs, n_channels, n_times, 1) or (n_epochs, 1, n_channels, n_times)\n",
"# We will use (n_epochs, 1, n_channels, n_times) for PyTorch compatibility (similar to 1-channel image)\n",
"X_tensor = torch.from_numpy(X_mock).unsqueeze(1)\n",
"\n",
"# Convert labels (T1=1, T2=2) to zero-indexed (0, 1)\n",
"le = LabelEncoder()\n",
"y_encoded = le.fit_transform(y_mock)\n",
"y_tensor = torch.from_numpy(y_encoded).long()\n",
"\n",
"print(f"Final Tensor Shape X: {X_tensor.shape}")\n",
"print(f"Final Label Shape y: {y_tensor.shape}")"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 3. Data Splitting and DataLoaders\n",
"\n",
"TEST_SIZE = 0.2\n",
"BATCH_SIZE = 16\n",
"\n",
"# Split into training and testing sets\n",
"X_train, X_test, y_train, y_test = train_test_split(\n",
"    X_tensor, y_tensor, test_size=TEST_SIZE, random_state=42, stratify=y_tensor\n",
")\n",
"\n",
"print(f"Training samples: {len(X_train)}")\n",
"print(f"Testing samples: {len(X_test)}")\n",
"\n",
"# Create PyTorch Datasets\n",
"train_dataset = TensorDataset(X_train, y_train)\n",
"test_dataset = TensorDataset(X_test, y_test)\n",
"\n",
"# Create DataLoaders\n",
"train_loader = DataLoader(train_dataset, batch_size=BATCH_SIZE, shuffle=True)\n",
"test_loader = DataLoader(test_dataset, batch_size=BATCH_SIZE, shuffle=False)"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 4. Model Initialization and Hyperparameters\n",
"\n",
"LEARNING_RATE = 0.001\n",
"NUM_EPOCHS = 50\n",
"\n",
"# Initialize EEGNet model (parameters matching PhysioNet data)\n",
"# F1=8, D=2, F2=16 (D*F1)\n",
"model = EEGNet(\n",
"    Chans=N_CHANNELS, \n",
"    Samples=N_TIMES, \n",
"    F1=8, \n",
"    D=2, \n",
"    F2=16, \n",
"    kernLength=64, \n",
"    num_classes=N_CLASSES\n",
").to(DEVICE)\n",
"\n",
"criterion = nn.CrossEntropyLoss()\n",
"optimizer = torch.optim.Adam(model.parameters(), lr=LEARNING_RATE, weight_decay=1e-3)\n",
"\n",
"print(model)"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 5. Training Loop\n",
"\n",
"print("Starting Baseline Training...")\n",
"history = []\n",
"\n",
"for epoch in range(NUM_EPOCHS):\n",
"    model.train()\n",
"    total_loss = 0\n",
"    for X_batch, y_batch in train_loader:\n",
"        X_batch, y_batch = X_batch.to(DEVICE), y_batch.to(DEVICE)\n",
"        \n",
"        # Forward pass\n",
"        optimizer.zero_grad()\n",
"        outputs = model(X_batch)\n",
"        loss = criterion(outputs, y_batch)\n",
"        \n",
"        # Backward pass and optimize\n",
"        loss.backward()\n",
"        optimizer.step()\n",
"        \n",
"        total_loss += loss.item() * X_batch.size(0)\n",
"\n",
"    # Calculate average loss\n",
"    avg_loss = total_loss / len(train_dataset)\n",
"    \n",
"    # Validation step (Evaluate on test set)\n",
"    model.eval()\n",
"    y_true_test = []\n",
"    y_pred_test = []\n",
"    with torch.no_grad():\n",
"        for X_batch, y_batch in test_loader:\n",
"            X_batch = X_batch.to(DEVICE)\n",
"            outputs = model(X_batch)\n",
"            _, predicted = torch.max(outputs.data, 1)\n",
"            \n",
"            y_true_test.extend(y_batch.cpu().numpy())\n",
"            y_pred_test.extend(predicted.cpu().numpy())\n",
"            \n",
"    test_accuracy = calculate_accuracy(np.array(y_true_test), np.array(y_pred_test))\n",
"    \n",
"    history.append({'loss': avg_loss, 'accuracy': test_accuracy})\n",
"\n",
"    if (epoch + 1) % 10 == 0 or epoch == 0:\n",
"        print(f'Epoch [{epoch+1}/{NUM_EPOCHS}], Loss: {avg_loss:.4f}, Test Acc: {test_accuracy:.4f}')\n",
"\n",
"print("Training Complete.")"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 6. Final Evaluation and Visualization\n",
"\n",
"final_acc = history[-1]['accuracy']\n",
"print(f"Final Baseline Test Accuracy: {final_acc:.4f}")\n",
"\n",
"# Plot training history\n",
"from utils.viz import plot_metrics_history\n",
"\n",
"plot_metrics_history(history, metrics=['accuracy', 'loss'], title='EEGNet Baseline Training Performance')\n",
"\n",
"# 7. Save the Model\n",
"MODEL_PATH = os.path.join('..', 'models', 'eegnet_baseline.pth')\n",
"torch.save(model.state_dict(), MODEL_PATH)\n",
"print(f"Model saved to {MODEL_PATH}")"
]
}
],
