"source": [
"# 01 - Data Exploration and Preprocessing (PhysioNet EEGMMIDB)\n",
"\n",
"This notebook demonstrates how to load the required Motor Imagery (MI) data from the PhysioNet EEG Motor Movement/Imagery Database (EEGMMIDB) using mne-python, perform initial visualization, and apply necessary preprocessing steps."
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 1. Setup and Imports\n",
"import numpy as np\n",
"import mne\n",
"import matplotlib.pyplot as plt\n",
"import sys\n",
"import os\n",
"\n",
"# Add the src directory to the path to import custom modules\n",
"sys.path.append(os.path.join('..', 'src'))\n",
"\n",
"from utils import viz\n",
"from data.load_datasets import load_physionet_subject_data\n",
"\n",
"# MNE configuration (Suppressing logging for cleaner output)\n",
"mne.set_log_level('WARNING')"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 2. Configuration\n",
"\n",
"SUBJECT_ID = 1 # Start with Subject 1\n",
"RUN_IDS = [4, 8, 12] # Runs corresponding to Motor Imagery: Left vs. Right hand\n",
"T_MIN, T_MAX = -1.0, 4.0 # Time window for epoching (relative to cue)\n",
"EVENT_ID = dict(T1=1, T2=2) # T1: Left Hand, T2: Right Hand"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 3. Load and Concatenate Raw Data\n",
"\n",
"# NOTE: This step assumes 'load_physionet_subject_data' is implemented in src/data/load_datasets.py\n",
"# and handles downloading if necessary.\n",
"\n",
"print(f"Loading Subject {SUBJECT_ID} Data...")\n",
"raw_list = load_physionet_subject_data(subject=SUBJECT_ID, runs=RUN_IDS)\n",
"\n",
"raw = mne.concatenate_raws(raw_list)\n",
"\n",
"print("Raw data loaded and concatenated.")\n",
"raw.info"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 4. Initial Visualization: Raw Data and Power Spectral Density (PSD)\n",
"\n",
"raw_data = raw.get_data()\n",
"ch_names = raw.ch_names\n",
"sfreq = raw.info['sfreq']\n",
"\n",
"# Plotting a short snippet of the raw data (first 3 seconds)\n",
"print("Plotting Raw Data (First 3s):")\n",
"viz.plot_eeg_raw(\n",
"    raw_data[:, :int(sfreq * 3)], \n",
"    sfreq=sfreq, \n",
"    ch_names=ch_names[:3], # Only show a few channels for clarity\n",
"    title=f"Raw EEG Data - Subject {SUBJECT_ID} (First 3 Channels)"\n",
")\n",
"\n",
"# Plotting PSD\n",
"print("Plotting Power Spectral Density:")\n",
"viz.plot_psd(\n",
"    raw_data[:len(ch_names), :], \n",
"    sfreq=sfreq, \n",
"    ch_names=ch_names, \n",
"    fmax=60, \n",
"    title=f"PSD - Subject {SUBJECT_ID}"\n",
")"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 5. Preprocessing Steps\n",
"\n",
"# A. Filtering (Bandpass)\n",
"# We filter between 7-30 Hz to focus on Alpha (8-12Hz) and Beta (15-30Hz) rhythms\n",
"# which are critical for Motor Imagery classification.\n",
"raw.filter(7.0, 30.0, fir_design='firwin', skip_by_annotation='edge')\n",
"\n",
"# B. Common Average Reference (CAR)\n",
"raw.set_eeg_reference('average', projection=True).apply_proj()\n",
"\n",
"# C. Find Events (Cue Timings)\n",
"events, event_id = mne.events_from_annotations(raw, event_id=EVENT_ID)\n",
"print(f"Found {len(events)} events for epoching.")\n",
"print(event_id)"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 6. Epoching\n",
"\n",
"epochs = mne.Epochs(raw,\n",
"                    events=events,\n",
"                    event_id=EVENT_ID,\n",
"                    tmin=T_MIN,\n",
"                    tmax=T_MAX,\n",
"                    baseline=(T_MIN, 0),\n",
"                    preload=True)\n",
"\n",
"print(f"Created {len(epochs)} clean epochs.")\n",
"\n",
"# D. Epoch Visualization (optional: check for artifacts)\n",
"# epochs.plot(n_epochs=5, n_channels=10, block=True)"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"# 7. Export Epochs\n",
"\n",
"X = epochs.get_data() # (n_epochs, n_channels, n_times)\n",
"y = epochs.events[:, 2] # Labels\n",
"\n",
"print(f"Data shape X: {X.shape}")\n",
"print(f"Label shape y: {y.shape}")\n",
"\n",
"# NOTE: In the next notebook (02_baseline_training.ipynb), we will split X and y \n",
"# into training and testing sets to train our EEGNet baseline model."
]
}
],
