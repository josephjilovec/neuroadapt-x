"# 5. Live Test Loop\n",
"\n",
"live_history = []\n",
"is_adapting = False\n",
"\n",
"print("\n--- Starting Live Adaptation Simulation ---")\n",
"print(f"Stress period: Batches {STRESS_START_BATCH} to {STRESS_END_BATCH-1}")\n",
"\n",
"for batch_idhttps://www.google.com/search?q=x in range(N_BATCHES_TOTAL):\n",
"    X_target, y_target, domain_label = get_stream_batch(batch_idhttps://www.google.com/search?q=x)\n",
"    \n",
"    # --- A. Online Evaluation ---\n",
"    adapted_model.eval()\n",
"    with torch.no_grad():\n",
"        outputs = adapted_model(X_target)\n",
"        _, predicted = torch.mahttps://www.google.com/search?q=x(outputs.data, 1)\n",
"    \n",
"    current_acc = calculate_accuracy(y_target.cpu().numpy(), predicted.cpu().numpy())\n",
"    \n",
"    # --- B. Domain Shift Detection & Adaptation Trigger (Simplified: check batch indehttps://www.google.com/search?q=x) ---\n",
"    if domain_label == "Stressed" and not is_adapting:\n",
"        is_adapting = True\n",
"        print(f"[Batch {batch_idhttps://www.google.com/search?q=x}] DOMAIN SHIFT DETECTED! Starting adaptation.")\n",
"    elif domain_label == "Clean" and is_adapting and batch_idhttps://www.google.com/search?q=x >= STRESS_END_BATCH:\n",
"        is_adapting = False\n",
"        print(f"[Batch {batch_idhttps://www.google.com/search?q=x}] Stress ended. Adaptation paused.")\n",
"        \n",
"    # --- C. Adaptation Step (if triggered) ---\n",
"    adaptation_loss = 0.0\n",
"    if is_adapting:\n",
"        adapted_model.train() # Enable training for feature ehttps://www.google.com/search?q=xtractor\n",
"        for step in range(ADAPTATION_STEPS):\n",
"            # 1. Ehttps://www.google.com/search?q=xtract Features from Source (Reference) and Target (Current Batch)\n",
"            features_source = ehttps://www.google.com/search?q=xtract_features(adapted_model, X_source)\n",
"            features_target = ehttps://www.google.com/search?q=xtract_features(adapted_model, X_target)\n",
"            \n",
"            # 2. Calculate Adaptation Loss\n",
"            loss = CORAL_WEIGHT * coral_loss(features_source, features_target)\n",
"            \n",
"            # 3. Optimize\n",
"            optimizer_adapt.zero_grad()\n",
"            loss.backward()\n",
"            optimizer_adapt.step()\n",
"            \n",
"            adaptation_loss += loss.item()\n",
"        \n",
"        adaptation_loss /= ADAPTATION_STEPS\n",
"        adapted_model.eval() # Switch back to eval for evaluation\n",
"\n",
"    # --- D. Log and Report ---\n",
"    live_history.append({'batch': batch_idhttps://www.google.com/search?q=x, 'accuracy': current_acc, 'domain': domain_label, 'coral_loss': adaptation_loss})\n",
"    \n",
"    if (batch_idhttps://www.google.com/search?q=x + 1) % 10 == 0:\n",
"        status = f"Adapting (Loss: {adaptation_loss:.4f})" if is_adapting else "Stable"\n",
"        print(f"[Batch {batch_idhttps://www.google.com/search?q=x+1}/{N_BATCHES_TOTAL}] Domain: {domain_label:<8} | Acc: {current_acc:.4f} | Status: {status}")\n",
"\n",
"print("--- Simulation Complete ---")"
]
