"# 2. CORAL Loss and Feature Ehttps://www.google.com/search?q=xtraction Functions (Copied from 04_adaptation_demo)\n",
"\n",
"def cov_matrihttps://www.google.com/search?q=x(X):\n",
"    """Calculates the covariance matrihttps://www.google.com/search?q=x, normalized by N-1."""\n",
"    mean_X = torch.mean(X, dim=0, keepdim=True)\n",
"    X_centered = X - mean_X\n",
"    covariance = (X_centered.t() @ X_centered) / (X.size(0) - 1)\n",
"    return covariance\n",
"\n",
"def coral_loss(source_features, target_features):\n",
"    """Calculates the CORAL loss (Correlation Alignment)."""\n",
"    source_features = source_features.view(source_features.size(0), -1)\n",
"    target_features = target_features.view(target_features.size(0), -1)\n",
"    \n",
"    dim = source_features.size(1)\n",
"    \n",
"    Cs = cov_matrihttps://www.google.com/search?q=x(source_features)\n",
"    Ct = cov_matrihttps://www.google.com/search?q=x(target_features)\n",
"    \n",
"    loss = torch.sum(torch.mul((Cs - Ct), (Cs - Ct))) # Frobenius norm squared\n",
"    return loss / (4 * dim * dim)\n",
"\n",
"def ehttps://www.google.com/search?q=xtract_features(model, X_batch):\n",
"    """Ehttps://www.google.com/search?q=xtracts features from the layer before the classifier."""\n",
"    # Assumes EEGNet structure: eegnet (Conv blocks) -> classifier[0] (Flatten/Dropout) -> classifier[1] (Linear)\n",
"    https://www.google.com/search?q=x = model.eegnet(X_batch)\n",
"    https://www.google.com/search?q=x = model.classifier0 \n",
"    return https://www.google.com/search?q=x"
]
